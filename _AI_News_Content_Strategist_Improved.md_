## 📊 Parse & Visualize Results

### Extract Structured Output

Convert the output to a readable format for content planning.

```python
def parse_content_calendar(result_text: str) -> dict:
    """
    Parse JSON output from the crew execution.
    
    Args:
        result_text (str): Raw result from crew.kickoff()
        
    Returns:
        dict: Parsed calendar data
        
    Raises:
        JSONDecodeError: If JSON is malformed
        
    Example:
        >>> calendar = parse_content_calendar(result)
        >>> print(calendar['weekly_calendar'][0]['title'])
    """
    try:
        # Extract JSON from result
        if '```json' in result_text:
            json_str = result_text.split('```json')[1].split('```')[0]
        elif '```' in result_text:
            json_str = result_text.split('```')[1].split('```')[0]
        else:
            # Try to find JSON object directly
            start = result_text.find('{')
            end = result_text.rfind('}') + 1
            json_str = result_text[start:end]
        
        calendar = json.loads(json_str)
        return calendar
    except Exception as e:
        print(f"⚠️  Error parsing JSON: {e}")
        return None

# Parse the calendar
calendar_data = parse_content_calendar(str(result))

if calendar_data:
    print("✅ Successfully parsed calendar data!\n")
```

### Display Calendar in Readable Format

```python
def display_calendar_summary(calendar_data: dict) -> None:
    """
    Display the content calendar in a readable format.
    
    Args:
        calendar_data (dict): Parsed calendar dictionary
        
    Example:
        >>> display_calendar_summary(calendar_data)
    """
    if not calendar_data or 'weekly_calendar' not in calendar_data:
        print("⚠️  No calendar data available")
        return
    
    days = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']
    
    for video in calendar_data['weekly_calendar']:
        day_name = days[video['day'] - 1]
        
        print(f"\n{'='*70}")
        print(f"📅 {day_name.upper()} (Day {video['day']})")
        print(f"{'='*70}")
        print(f"\n📌 Title:\n   {video['title']}")
        print(f"\n🎯 Primary Hook:\n   {video['hook_primary']}")
        
        if 'hook_alternative' in video:
            print(f"\n🎯 Alternative Hook:\n   {video['hook_alternative']}")
        
        print(f"\n💡 Main Insight:\n   {video['main_insight']}")
        
        print(f"\n🎬 Visual Ideas:")
        for visual in video['visuals']:
            print(f"   • {visual}")
        
        if 'pacing' in video:
            print(f"\n⏱️  Pacing Strategy:\n   {video['pacing']}")
        
        print(f"\n🏷️  Hashtags:")
        print(f"   {' '.join(['#' + tag for tag in video['hashtags']])}")
        
        print(f"\n📢 Call-to-Action:\n   {video['cta']}")
    
    print(f"\n{'='*70}\n")

# Display the calendar
if calendar_data:
    display_calendar_summary(calendar_data)
```

### Save Calendar to File

```python
def save_calendar_to_file(
    calendar_data: dict,
    filename: str = "ai_content_calendar.json"
) -> None:
    """
    Save the content calendar to a JSON file.
    
    Args:
        calendar_data (dict): Calendar data to save
        filename (str): Output filename (default: "ai_content_calendar.json")
        
    Example:
        >>> save_calendar_to_file(calendar_data, "weekly_plan.json")
    """
    try:
        with open(filename, 'w') as f:
            json.dump(calendar_data, f, indent=2)
        print(f"✅ Calendar saved to: {filename}")
    except Exception as e:
        print(f"❌ Error saving file: {e}")

# Save the calendar
if calendar_data:
    save_calendar_to_file(calendar_data)
```

